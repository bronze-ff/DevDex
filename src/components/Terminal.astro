---
// Terminal.astro — janela de terminal estilizada (visual; NÃO executa de verdade).
// Uso (MDX):
//   import Terminal from '../../../components/Terminal.astro';
//   <Terminal label="nu" title="nushell">
//   > winget install nushell
//   </Terminal>
interface Props {
  /** rótulo curto à esquerda (ex.: nu, pwsh, bash, docker) */
  label?: string;
  /** título/contexto (ex.: nushell, ~/projeto) */
  title?: string;
}
const { label = '>_', title = 'terminal' } = Astro.props;
---

<div class="ddx-term" data-ddx-term>
  <div class="ddx-term__bar">
    <span class="ddx-term__dots" aria-hidden="true"><i></i><i></i><i></i></span>
    <span class="ddx-term__title">{label} · {title}</span>
    <button class="ddx-term__copy" type="button" aria-label="Copiar comandos">Copiar</button>
  </div>
  <pre class="ddx-term__body"><slot /></pre>
</div>

<script>
  function wireTerminals() {
    document.querySelectorAll('[data-ddx-term]').forEach((el) => {
      const btn = el.querySelector('.ddx-term__copy');
      const body = el.querySelector('.ddx-term__body');
      if (!btn || !body || btn.dataset.wired) return;
      btn.dataset.wired = '1';
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText((body.textContent || '').trim());
          const original = btn.textContent;
          btn.textContent = 'Copiado!';
          btn.classList.add('is-copied');
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove('is-copied');
          }, 1500);
        } catch {
          /* clipboard indisponível (ex.: http sem https) */
        }
      });
    });
  }
  document.addEventListener('astro:page-load', wireTerminals);
</script>
