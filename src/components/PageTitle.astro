---
const title = Astro.locals.starlightRoute.entry.data.title;
---

<div class="devdex-title-row">
  <h1 id="_top">{title}</h1>
  <button
    id="copy-article-btn"
    class="copy-article-btn"
    aria-label="Copiar conteúdo do artigo"
    title="Copiar conteúdo do artigo"
    type="button"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
      <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
    </svg>
    <span class="copy-label">Copiar artigo</span>
  </button>
</div>

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
  }

  .devdex-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .devdex-title-row h1 {
    flex: 1;
    min-width: 0;
  }

  .copy-article-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.35rem 0.7rem;
    margin-top: 1.15rem;
    flex-shrink: 0;
    border-radius: 6px;
    border: 1px solid var(--sl-color-gray-5);
    background: transparent;
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    font-family: var(--sl-font);
    cursor: pointer;
    white-space: nowrap;
    transition:
      color 150ms ease,
      border-color 150ms ease,
      background 150ms ease;
  }

  .copy-article-btn:hover {
    color: var(--sl-color-white);
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
  }

  .copy-article-btn:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .copy-article-btn.copied {
    color: #4ade80;
    border-color: #4ade80;
  }
</style>

<script>
  function initCopyButton() {
    const btn = document.getElementById('copy-article-btn') as HTMLButtonElement | null;
    if (!btn) return;

    btn.addEventListener('click', async () => {
      const content = document.querySelector('.sl-markdown-content') as HTMLElement | null;
      if (!content) return;

      try {
        await navigator.clipboard.writeText(content.innerText);

        const label = btn.querySelector('.copy-label');
        btn.classList.add('copied');
        if (label) label.textContent = 'Copiado!';

        setTimeout(() => {
          btn.classList.remove('copied');
          if (label) label.textContent = 'Copiar artigo';
        }, 2000);
      } catch {
        // fallback silencioso — clipboard não disponível (ex: HTTP sem HTTPS)
      }
    });
  }

  // Starlight usa View Transitions — re-inicializa no cada troca de página
  document.addEventListener('astro:page-load', initCopyButton);
</script>
